# Optional. Leave unset to auto-detect the backend on the same machine that serves
# the Expo bundle (works in Expo Go on the same Wi-Fi when the backend listens on
# 0.0.0.0:8000). Set it to reach a backend elsewhere, e.g. a tunnel:
#   EXPO_PUBLIC_API_URL=https://your-subdomain.trycloudflare.com
# Copy this file to .env (only EXPO_PUBLIC_* vars are exposed to the app).
EXPO_PUBLIC_API_URL=
